def calculate_hourly_metrics(hourly):
    """Calcola metriche di errore a livello orario su tutto il dataset"""
    
    mask = hourly['pvgis_ref_kwh'] > 0
    hourly_valid = hourly[mask].copy()
    
    err = hourly_valid['prod_h'] - hourly_valid['pvgis_ref_kwh']
    rel_err = (err / hourly_valid['pvgis_ref_kwh']) * 100
    
    mbe = np.mean(err)
    mae = np.mean(np.abs(err))
    rmse = np.sqrt(np.mean(err**2))
    mape = np.mean(np.abs(rel_err))
    nrmse = rmse / hourly_valid['pvgis_ref_kwh'].mean() * 100
    mape_median = np.median(np.abs(rel_err))
    
    ss_res = np.sum(err**2)
    ss_tot = np.sum((hourly_valid['pvgis_ref_kwh'] - hourly_valid['pvgis_ref_kwh'].mean())**2)
    r2 = 1 - (ss_res / ss_tot)
    
    # Percentuali di ore entro soglie di errore: 1%, 2%, 3%
    pct_err_1pct = (np.abs(rel_err) < 1).mean() * 100
    pct_err_2pct = (np.abs(rel_err) < 2).mean() * 100
    pct_err_3pct = (np.abs(rel_err) < 3).mean() * 100
    
    print("\n" + "="*60)
    print("ERROR METRICS - HOURLY SCALE (all hours)")
    print("="*60)
    print(f"MBE   (Mean Bias Error):          {mbe:.5f} kWh")
    print(f"MAE   (Mean Absolute Error):      {mae:.5f} kWh")
    print(f"RMSE  (Root Mean Square Error):   {rmse:.5f} kWh")
    print(f"MAPE  (Mean Absolute % Error):    {mape:.2f}%")
    print(f"MdAPE (Median Absolute % Error):  {mape_median:.2f}%")
    print(f"NRMSE (Normalized RMSE):          {nrmse:.2f}%")
    print(f"R²    (Coefficient of determination): {r2:.4f}")
    print(f"\n📊 Ore entro soglie di errore:")
    print(f"   Errore < 1%:  {pct_err_1pct:.1f}% delle ore")
    print(f"   Errore < 2%:  {pct_err_2pct:.1f}% delle ore")
    print(f"   Errore < 3%:  {pct_err_3pct:.1f}% delle ore")
    print("="*60)
    
    return {
        'MBE_kWh': mbe,
        'MAE_kWh': mae,
        'RMSE_kWh': rmse,
        'MAPE_perc': mape,
        'MdAPE_perc': mape_median,
        'NRMSE_perc': nrmse,
        'R2': r2,
        'N_hours': len(hourly_valid),
        'pct_error_lt_1': pct_err_1pct,
        'pct_error_lt_2': pct_err_2pct,
        'pct_error_lt_3': pct_err_3pct
    }


def create_hourly_statistical_evidence(hourly):
    """Crea tabella statistica per dimostrare accuratezza oraria"""
    
    mask = hourly['pvgis_ref_kwh'] > 0.001
    hourly_valid = hourly[mask].copy()
    
    err = hourly_valid['prod_h'] - hourly_valid['pvgis_ref_kwh']
    rel_err = (err / hourly_valid['pvgis_ref_kwh']) * 100
    
    # Intervallo di confidenza al 95% per MBE
    conf_interval = [
        np.mean(err) - 1.96 * np.std(err) / np.sqrt(len(err)),
        np.mean(err) + 1.96 * np.std(err) / np.sqrt(len(err))
    ]
    
    stats_table = pd.DataFrame({
        'Metrica': [
            'Numero ore analizzate',
            'Errore medio orario (MBE)',
            'Errore assoluto medio (MAE)',
            'Errore quadratico medio (RMSE)',
            'Errore percentuale medio (MAPE)',
            'Mediana errore percentuale (MdAPE)',
            'Deviazione standard errore',
            'Intervallo di confidenza 95% (MBE)',
            'Percentuale ore con errore < 1%',
            'Percentuale ore con errore < 2%',
            'Percentuale ore con errore < 3%',
            'Massimo errore assoluto',
            'Minimo errore assoluto (non zero)'
        ],
        'Valore': [
            f"{len(hourly_valid)}",
            f"{np.mean(err):.5f} kWh",
            f"{np.mean(np.abs(err)):.5f} kWh",
            f"{np.sqrt(np.mean(err**2)):.5f} kWh",
            f"{np.mean(np.abs(rel_err)):.2f}%",
            f"{np.median(np.abs(rel_err)):.2f}%",
            f"{np.std(err):.5f} kWh",
            f"[{conf_interval[0]:.5f}, {conf_interval[1]:.5f}] kWh",
            f"{(np.abs(rel_err) < 1).mean() * 100:.1f}%",
            f"{(np.abs(rel_err) < 2).mean() * 100:.1f}%",
            f"{(np.abs(rel_err) < 3).mean() * 100:.1f}%",
            f"{np.max(np.abs(err)):.5f} kWh",
            f"{np.min(np.abs(err)[np.abs(err) > 0]):.5f} kWh"
        ]
    })
    
    print("\n" + "="*70)
    print("📊 EVIDENZA STATISTICA - ACCURATEZZA ORARIA")
    print("="*70)
    print(stats_table.to_string(index=False))
    print("="*70)
    
    return stats_table


def perform_statistical_tests(hourly):
    """Test statistici per dimostrare similarità tra modello e PVGIS"""
    
    mask = hourly['pvgis_ref_kwh'] > 0.001
    model = hourly.loc[mask, 'prod_h'].values
    pvgis = hourly.loc[mask, 'pvgis_ref_kwh'].values
    diff = model - pvgis
    
    # Test di Wilcoxon
    wilcoxon_stat, wilcoxon_p = wilcoxon(model, pvgis)
    
    # Correlazione di Spearman
    spearman_corr, spearman_p = spearmanr(model, pvgis)
    
    # Test t di Student
    t_stat, t_p = ttest_1samp(diff, 0)
    
    # Test di Kolmogorov-Smirnov
    ks_stat, ks_p = ks_2samp(model, pvgis)
    
    # Test di normalità (Shapiro-Wilk) sugli errori
    sample_size = min(5000, len(diff))
    sample_diff = np.random.choice(diff, sample_size, replace=False)
    shapiro_stat, shapiro_p = shapiro(sample_diff)
    
    results = pd.DataFrame({
        'Test Statistico': [
            'Wilcoxon signed-rank',
            'Spearman correlation',
            'Student t-test (diff = 0)',
            'Kolmogorov-Smirnov',
            'Shapiro-Wilk (normalità errori)'
        ],
        'Statistica': [
            f"{wilcoxon_stat:.2f}",
            f"{spearman_corr:.6f}",
            f"{t_stat:.4f}",
            f"{ks_stat:.4f}",
            f"{shapiro_stat:.4f}"
        ],
        'p-value': [
            f"{wilcoxon_p:.4e}",
            f"{spearman_p:.4e}",
            f"{t_p:.4e}",
            f"{ks_p:.4e}",
            f"{shapiro_p:.4e}"
        ],
        'Interpretazione (α=0.05)': [
            '✅ Non rifiuto H0 (distribuzioni uguali)' if wilcoxon_p > 0.05 else '❌ Rifiuto H0',
            f'✅ Correlazione {"perfetta" if spearman_corr > 0.999 else "forte"}' if spearman_p < 0.05 else '❌ Correlazione non significativa',
            '✅ Non rifiuto H0 (media diff = 0)' if t_p > 0.05 else '❌ Rifiuto H0',
            '✅ Stessa distribuzione' if ks_p > 0.05 else '❌ Distribuzioni diverse',
            '✅ Errori normali' if shapiro_p > 0.05 else '⚠️ Errori non normali (accettabile per grandi n)'
        ]
    })
    
    print("\n" + "="*70)
    print("📈 TEST STATISTICI - CONFRONTO MODELLO vs PVGIS")
    print("="*70)
    print(results.to_string(index=False))
    print("="*70)
    print("\n📝 NOTE:")
    print("- H0 = le due distribuzioni sono uguali / la differenza media è zero")
    print("- p-value > 0.05 → nessuna evidenza statistica di differenza")
    print("- Correlazione di Spearman > 0.999 → relazione quasi perfetta")
    
    return results


def analyze_residuals_by_hour_month(hourly):
    """Analisi dei residui per ora e mese"""
    
    mask = hourly['pvgis_ref_kwh'] > 0.001
    hourly_valid = hourly[mask].copy()
    
    hourly_valid['error'] = hourly_valid['prod_h'] - hourly_valid['pvgis_ref_kwh']
    hourly_valid['rel_error'] = (hourly_valid['error'] / hourly_valid['pvgis_ref_kwh']) * 100
    hourly_valid['hour'] = hourly_valid.index.hour
    hourly_valid['month'] = hourly_valid.index.month
    
    # Tabella errori per fascia oraria
    hourly_error_by_hour = hourly_valid.groupby('hour')['rel_error'].agg([
        ('Media (%)', 'mean'),
        ('Mediana (%)', 'median'),
        ('Std Dev (%)', 'std'),
        ('Q1 (%)', lambda x: x.quantile(0.25)),
        ('Q3 (%)', lambda x: x.quantile(0.75))
    ]).round(2)
    
    # Tabella errori per mese
    monthly_error = hourly_valid.groupby('month')['rel_error'].agg([
        ('Media (%)', 'mean'),
        ('Mediana (%)', 'median'),
        ('Std Dev (%)', 'std')
    ]).round(2)
    
    mesi_nomi = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 
                 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
    monthly_error.index = mesi_nomi
    
    print("\n" + "="*70)
    print("🔍 ANALISI RESIDUI - ERRORI PER ORA DEL GIORNO")
    print("="*70)
    print(hourly_error_by_hour.to_string())
    
    print("\n" + "="*70)
    print("📅 ANALISI RESIDUI - ERRORI PER MESE")
    print("="*70)
    print(monthly_error.to_string())
    print("="*70)
    
    # Verifica se gli errori medi per ora sono tutti prossimi a zero
    max_abs_mean_hour = np.max(np.abs(hourly_error_by_hour['Media (%)'].values))
    print(f"\n✅ Verifica bias orario: massimo |errore medio| = {max_abs_mean_hour:.2f}%")
    if max_abs_mean_hour < 2:
        print("   → Nessun bias orario significativo (< 2%)")
    else:
        print(f"   → Attenzione: bias orario rilevante ({max_abs_mean_hour:.2f}%)")
    
    return hourly_error_by_hour, monthly_error


