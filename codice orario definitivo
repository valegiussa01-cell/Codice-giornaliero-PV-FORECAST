def analyze_seasonal_performance(hourly, daily):
    """Analisi dettagliata delle performance stagionali"""
    
    # Definizione stagioni
    hourly['season'] = hourly.index.month.map({
        12: 'Winter', 1: 'Winter', 2: 'Winter',
        3: 'Spring', 4: 'Spring', 5: 'Spring',
        6: 'Summer', 7: 'Summer', 8: 'Summer',
        9: 'Autumn', 10: 'Autumn', 11: 'Autumn'
    })
    
    daily['season'] = daily.index.month.map({
        12: 'Winter', 1: 'Winter', 2: 'Winter',
        3: 'Spring', 4: 'Spring', 5: 'Spring',
        6: 'Summer', 7: 'Summer', 8: 'Summer',
        9: 'Autumn', 10: 'Autumn', 11: 'Autumn'
    })
    
    seasons_order = ['Winter', 'Spring', 'Summer', 'Autumn']
    seasons_names = {'Winter': 'Inverno (Dec-Feb)', 'Spring': 'Primavera (Mar-May)',
                     'Summer': 'Estate (Jun-Aug)', 'Autumn': 'Autunno (Sep-Nov)'}
    
    # 1. Metriche stagionali orarie
    print("\n" + "="*80)
    print("🌿 ANALISI STAGIONALE - PERFORMANCE ORARIE")
    print("="*80)
    
    seasonal_hourly_metrics = []
    for season in seasons_order:
        season_data = hourly[hourly['season'] == season]
        mask = season_data['pvgis_ref_kwh'] > 0
        season_valid = season_data[mask]
        
        if len(season_valid) > 0:
            err = season_valid['prod_h'] - season_valid['pvgis_ref_kwh']
            rel_err = (err / season_valid['pvgis_ref_kwh']) * 100
            
            seasonal_hourly_metrics.append({
                'Stagione': seasons_names[season],
                'Ore analizzate': len(season_valid),
                'MBE (kWh)': np.mean(err),
                'MAE (kWh)': np.mean(np.abs(err)),
                'RMSE (kWh)': np.sqrt(np.mean(err**2)),
                'MAPE (%)': np.mean(np.abs(rel_err)),
                'Mediana MAPE (%)': np.median(np.abs(rel_err)),
                'Ore con errore <3% (%)': (np.abs(rel_err) < 3).mean() * 100
            })
    
    seasonal_df = pd.DataFrame(seasonal_hourly_metrics)
    print(seasonal_df.to_string(index=False))
    
    # 2. Metriche stagionali giornaliere
    print("\n" + "="*80)
    print("📆 ANALISI STAGIONALE - PERFORMANCE GIORNALIERE")
    print("="*80)
    
    seasonal_daily_metrics = []
    for season in seasons_order:
        season_data = daily[daily['season'] == season]
        if len(season_data) > 0:
            err = season_data['prod_mio'] - season_data['prod_pvgis']
            rel_err = (err / season_data['prod_pvgis']) * 100
            
            seasonal_daily_metrics.append({
                'Stagione': seasons_names[season],
                'Giorni': len(season_data),
                'Prod_Media_Modello (kWh)': season_data['prod_mio'].mean(),
                'Prod_Media_PVGIS (kWh)': season_data['prod_pvgis'].mean(),
                'MBE (kWh)': np.mean(err),
                'MAE (kWh)': np.mean(np.abs(err)),
                'MAPE (%)': np.mean(np.abs(rel_err)),
                'T_Ambiente_Media (°C)': season_data['temp_ambiente_media_c'].mean(),
                'T_Cella_Media (°C)': season_data['temp_cella_media_c'].mean(),
                'Efficienza_Pannello (%)': season_data['eff_pannello_perc'].mean()
            })
    
    seasonal_daily_df = pd.DataFrame(seasonal_daily_metrics)
    print(seasonal_daily_df.to_string(index=False))
    
    return seasonal_df, seasonal_daily_df


