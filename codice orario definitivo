def plot_clear_sky_vs_cloudy_day(hourly):
    """Grafico 1: Confronto Cielo Sereno vs Giorno Nuvoloso"""
    
    hourly['hour'] = hourly.index.hour
    daily_stats = hourly.groupby(hourly.index.date).agg({
        'prod_h': ['sum', 'std'],
        'pvgis_ref_kwh': ['sum', 'std']
    })
    daily_stats.columns = ['prod_sum', 'prod_std', 'pvgis_sum', 'pvgis_std']
    daily_stats['variability'] = daily_stats['prod_std'] / (daily_stats['prod_sum'] + 0.001)
    
    clear_sky_date = daily_stats[daily_stats['prod_sum'] > daily_stats['prod_sum'].quantile(0.8)]
    clear_sky_date = clear_sky_date[clear_sky_date['variability'] < clear_sky_date['variability'].quantile(0.2)]
    clear_sky_date = clear_sky_date.index[0]
    
    cloudy_date = daily_stats[daily_stats['variability'] > daily_stats['variability'].quantile(0.8)].index[0]
    
    print(f"\n🔍 Giorni selezionati per confronto:")
    print(f"   Cielo Sereno: {clear_sky_date}")
    print(f"   Giorno Nuvoloso: {cloudy_date}")
    
    clear_data = hourly[hourly.index.date == clear_sky_date].copy()
    cloudy_data = hourly[hourly.index.date == cloudy_date].copy()
    
