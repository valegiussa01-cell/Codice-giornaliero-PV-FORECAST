def create_hourly_summary_table(hourly_metrics, hourly):
    """Tabella riassuntiva giorno/notte"""
    
    hourly['hour'] = hourly.index.hour
    day_mask = (hourly['hour'] >= 6) & (hourly['hour'] <= 18)
    night_mask = ~day_mask
    
    def calc_fleet_metrics(data):
        if len(data) == 0 or data['pvgis_ref_kwh'].sum() == 0:
            return {'MAE': np.nan, 'MAPE': np.nan, 'MBE': np.nan}
        err = data['prod_h'] - data['pvgis_ref_kwh']
        mask = data['pvgis_ref_kwh'] > 0
        return {
            'MAE': np.mean(np.abs(err)),
            'MAPE': np.mean(np.abs(err[mask] / data.loc[mask, 'pvgis_ref_kwh'])) * 100 if mask.any() else np.nan,
            'MBE': np.mean(err)
        }
    
    day_metrics = calc_fleet_metrics(hourly[day_mask])
    night_metrics = calc_fleet_metrics(hourly[night_mask])
    
    summary_df = pd.DataFrame({
        'Metric': ['MAE (kWh)', 'MAPE (%)', 'MBE (kWh)', 'RMSE (kWh)', 'R²', 'N hours'],
        'All Hours': [
            f"{hourly_metrics['MAE_kWh']:.5f}",
            f"{hourly_metrics['MAPE_perc']:.2f}",
            f"{hourly_metrics['MBE_kWh']:.5f}",
            f"{hourly_metrics['RMSE_kWh']:.5f}",
            f"{hourly_metrics['R2']:.4f}",
            hourly_metrics['N_hours']
        ],
        'Daytime (6-18h)': [
            f"{day_metrics['MAE']:.5f}" if not np.isnan(day_metrics['MAE']) else 'N/A',
            f"{day_metrics['MAPE']:.2f}" if not np.isnan(day_metrics['MAPE']) else 'N/A',
            f"{day_metrics['MBE']:.5f}" if not np.isnan(day_metrics['MBE']) else 'N/A',
            'N/A', 'N/A',
            len(hourly[day_mask])
        ],
        'Nighttime (19-5h)': [
            f"{night_metrics['MAE']:.5f}" if not np.isnan(night_metrics['MAE']) else 'N/A',
            f"{night_metrics['MAPE']:.2f}" if not np.isnan(night_metrics['MAPE']) else 'N/A',
            f"{night_metrics['MBE']:.5f}" if not np.isnan(night_metrics['MBE']) else 'N/A',
            'N/A', 'N/A',
            len(hourly[night_mask])
        ]
    })
    
    print("\n" + "="*70)
    print("📊 HOURLY METRICS SUMMARY TABLE (Day vs Night)")
    print("="*70)
    print(summary_df.to_string(index=False))
    print("="*70)
    
    return summary_df


def export_to_excel(daily, monthly, hourly, metrics, hourly_metrics, statistical_tests, 
                    hourly_summary, validation_summary, filename='production_pv_dublin.xlsx'):
    """Esporta tutti i risultati in Excel"""
    
    print(f"\n[3/3] Exporting data to Excel...")
    
    final_filename = filename
    try:
        with pd.ExcelWriter(final_filename, engine='openpyxl') as writer:
            # Sheet 1: Daily data
            daily_export = daily[['data_str', 'giorno', 'mese', 'prod_mio', 'prod_pvgis', 
                                  'errore_kwh', 'errore_perc', 'temp_ambiente_media_c', 
                                  'temp_cella_media_c', 'eff_pannello_perc', 'eff_sistema_perc']].copy()
            daily_export.columns = ['Date (Month-Day)', 'Day', 'Month', 'Model_Prod_kWh', 
                                    'PVGIS_Prod_kWh', 'Error_kWh', 'Error_%', 
                                    'Ambient_Temp_°C', 'Cell_Temp_°C', 
                                    'Panel_Efficiency_%', 'System_Efficiency_%']
            daily_export.to_excel(writer, sheet_name='Daily_Data', index=False)
            
            # Sheet 2: Monthly data
            monthly_export = monthly.reset_index()
            months_names = ['January', 'February', 'March', 'April', 'May', 'June',
                           'July', 'August', 'September', 'October', 'November', 'December']
            monthly_export['Month'] = months_names
            monthly_export = monthly_export[['Month', 'prod_mio', 'prod_pvgis', 'errore_kwh', 'errore_perc',
                                             'temp_ambiente_media_c', 'temp_cella_media_c', 
                                             'eff_pannello_perc', 'eff_sistema_perc']]
            monthly_export.columns = ['Month', 'Model_Prod_kWh', 'PVGIS_Prod_kWh', 'Error_kWh', 'Error_%',
                                      'Avg_Ambient_Temp_°C', 'Avg_Cell_Temp_°C',
                                      'Avg_Panel_Efficiency_%', 'Avg_System_Efficiency_%']
            monthly_export.to_excel(writer, sheet_name='Monthly_Data', index=False)
            
            # Sheet 3: Hourly data
            hourly_export = hourly.copy()
            hourly_export['datetime'] = hourly_export.index
            hourly_export = hourly_export[['datetime', 'poa_global', 'temp_air', 't_cell', 
                                           'eff_panel', 'eff_system', 'prod_h', 'pvgis_ref_kwh']]
            hourly_export.columns = ['Datetime', 'POA_Global_W/m2', 'Ambient_Temp_°C', 'Cell_Temp_°C',
                                     'Panel_Efficiency_frac', 'System_Efficiency_frac', 
