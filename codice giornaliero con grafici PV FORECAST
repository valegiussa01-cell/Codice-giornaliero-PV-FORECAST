            hourly_export.to_excel(writer, sheet_name='Hourly_Data', index=False)
            
            # Sheet 4: Annual metrics
            metrics_annual_df = pd.DataFrame(list(metrics['Annual'].items()), columns=['Metric', 'Value'])
            metrics_annual_df.to_excel(writer, sheet_name='Annual_Metrics', index=False)
            
            # Sheet 5: Monthly metrics
            metrics['Monthly'].to_excel(writer, sheet_name='Monthly_Metrics', index=False)
            
            # Sheet 6: Hourly metrics
            hourly_metrics_df = pd.DataFrame([
                ['MBE (kWh)', hourly_metrics['MBE_kWh']],
                ['MAE (kWh)', hourly_metrics['MAE_kWh']],
                ['RMSE (kWh)', hourly_metrics['RMSE_kWh']],
                ['MAPE (%)', hourly_metrics['MAPE_perc']],
                ['MdAPE (%)', hourly_metrics['MdAPE_perc']],
                ['NRMSE (%)', hourly_metrics['NRMSE_perc']],
                ['R²', hourly_metrics['R2']],
                ['Valid hours (PVGIS > 0)', hourly_metrics['N_hours']],
                ['Hours with error < 5% (%)', hourly_metrics['pct_error_lt_5']],
                ['Hours with error < 10% (%)', hourly_metrics['pct_error_lt_10']]
            ], columns=['Metric', 'Value'])
            hourly_metrics_df.to_excel(writer, sheet_name='Hourly_Metrics', index=False)
            
            # Sheet 7: Statistical tests
            statistical_tests.to_excel(writer, sheet_name='Statistical_Tests', index=False)
            
            # Sheet 8: Hourly summary by period
            hourly_summary.to_excel(writer, sheet_name='Hourly_Summary_Periods', index=False)
            
            # Sheet 9: Validation summary
            validation_summary.to_excel(writer, sheet_name='Validation_Summary', index=False)
            
            # Sheet 10: System configuration
            config_data = {
                'Parameter': [
                    'Installed Power (kWp)', 'Latitude', 'Longitude', 'Tilt Angle', 
                    'Azimuth', 'Number of Panels', 'Total Area (m²)', 'Panel Efficiency STC', 
                    'Performance Ratio (PR)', 'Inverter Efficiency', 'PVGIS Data Period',
                    'Calendar Year', 'Data Type', 'Important Note'
                ],
                'Value': [
                    round(5 * 0.435, 2), 53.383, -6.592, 30, 180, 5, 
                    round(1.762*1.134*5, 2), '21.8%', '94%', '96%',
                    '2005-2020', '2015 (calendar only)', 'TMY - Typical Meteorological Year',
                    'Values are climatological averages for 2005-2020, not actual 2015 data'
                ]
            }
            config_df = pd.DataFrame(config_data)
            config_df.to_excel(writer, sheet_name='System_Configuration', index=False)
        
        print(f"      File saved: {final_filename}")
        
    except PermissionError:
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        final_filename = filename.replace('.xlsx', f'_{timestamp}.xlsx')
        print(f"      File {filename} is open. Saving as: {final_filename}")
        
        with pd.ExcelWriter(final_filename, engine='openpyxl') as writer:
            daily_export.to_excel(writer, sheet_name='Daily_Data', index=False)
            monthly_export.to_excel(writer, sheet_name='Monthly_Data', index=False)
            hourly_export.to_excel(writer, sheet_name='Hourly_Data', index=False)
            metrics_annual_df.to_excel(writer, sheet_name='Annual_Metrics', index=False)
            metrics['Monthly'].to_excel(writer, sheet_name='Monthly_Metrics', index=False)
            hourly_metrics_df.to_excel(writer, sheet_name='Hourly_Metrics', index=False)
            statistical_tests.to_excel(writer, sheet_name='Statistical_Tests', index=False)
            hourly_summary.to_excel(writer, sheet_name='Hourly_Summary_Periods', index=False)
            validation_summary.to_excel(writer, sheet_name='Validation_Summary', index=False)
            config_df.to_excel(writer, sheet_name='System_Configuration', index=False)
        
        print(f"      File saved as: {final_filename}")
    
    print(f"      NOTE: Data represents a TYPICAL METEOROLOGICAL YEAR (2005-2020 averages)")


